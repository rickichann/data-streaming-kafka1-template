{
  "name": "iceberg-sink",
  "config": {
    "connector.class": "org.apache.iceberg.connect.IcebergSinkConnector",
    "topics": "cdc.public.products",
    "iceberg.catalog.type": "rest",
    "iceberg.catalog.uri": "https://s3tables.ap-southeast-3.amazonaws.com/iceberg",
    "iceberg.catalog.warehouse": "arn:aws:s3tables:ap-southeast-3:339712808680:bucket/dbstream2026",
    "iceberg.catalog.client.region": "ap-southeast-3",
    "iceberg.catalog.rest.signing-region": "ap-southeast-3",
    "iceberg.catalog.rest.signing-name": "s3tables",
    "iceberg.catalog.rest.sigv4-enabled": "true",
    "iceberg.catalog.io-impl": "org.apache.iceberg.aws.s3.S3FileIO",
    "iceberg.tables": "inventory.products",
    "iceberg.tables.auto-create-enabled": "true",
    "iceberg.tables.evolve-schema-enabled": "true",
    "iceberg.tables.upsert-mode-enabled": "false",
    "iceberg.tables.dynamic-enabled": "false",
    "iceberg.control.topic": "iceberg-connector-control-v1",
    "iceberg.control.commit.interval-ms": "60000",
    "key.converter": "org.apache.kafka.connect.json.JsonConverter",
    "key.converter.schemas.enable": "true",
    "value.converter": "org.apache.kafka.connect.json.JsonConverter",
    "value.converter.schemas.enable": "true"
  }
}
